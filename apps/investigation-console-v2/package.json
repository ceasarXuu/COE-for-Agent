{
  "name": "@coe/investigation-console-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch ../investigation-console/server/index.ts",
    "dev:web": "vite",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@coe/console-client": "workspace:*",
    "@coe/domain": "workspace:*",
    "@coe/shared-utils": "workspace:*",
    "@coe/ui": "workspace:*",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.2.1",
    "concurrently": "^9.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^6.30.1",
    "reactflow": "^11.11.4",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}

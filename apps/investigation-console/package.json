{
  "name": "@coe/investigation-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "sh ./node_modules/.bin/vitest run",
    "test:e2e": "node scripts/run-e2e.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@coe/domain": "workspace:*",
    "@coe/investigation-server": "workspace:*",
    "@coe/shared-utils": "workspace:*",
    "@coe/telemetry": "workspace:*",
    "fastify": "^5.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}

{
  "name": "@coe/investigation-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bootstrap:hosts": "node --import tsx ./src/bootstrap/host-bootstrap-cli.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "mcp:stdio": "node --import tsx ./src/mcp/stdio-entry.ts",
    "test": "vitest run --maxWorkers=1 --testTimeout=30000 --hookTimeout=30000",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@coe/domain": "workspace:*",
    "@coe/mcp-contracts": "workspace:*",
    "@coe/persistence": "workspace:*",
    "@coe/schemas": "workspace:*",
    "@coe/telemetry": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.6.1",
    "kysely": "^0.28.2"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "pg": "^8.16.3",
    "tsx": "^4.20.6",
    "vitest": "^3.1.2"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/common/command-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "warnings",
    "violations",
    "headRevisionBefore",
    "headRevisionAfter",
    "projectionScheduled"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "eventId": { "type": "string" },
    "createdIds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "updatedIds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errorCode": { "type": "string" },
    "message": { "type": "string" },
    "headRevisionBefore": { "type": "integer", "minimum": 0 },
    "headRevisionAfter": { "type": "integer", "minimum": 0 },
    "projectionScheduled": { "type": "boolean" },
    "snapshotDelta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
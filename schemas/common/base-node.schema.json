{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/common/base-node.schema.json",
  "type": "object",
  "required": ["kind", "id", "schemaVersion", "caseId", "revision", "createdAt", "createdBy"],
  "properties": {
    "kind": {
      "type": "string",
      "pattern": "^investigation\\.[a-z_]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]+_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "caseId": {
      "type": "string",
      "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "$ref": "./actor-ref.schema.json"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true
    }
  }
}
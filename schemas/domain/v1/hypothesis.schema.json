{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/domain/v1/hypothesis.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "caseId", "parentNodeId", "statement", "falsificationCriteria", "status"],
  "properties": {
    "kind": { "const": "investigation.hypothesis" },
    "id": { "type": "string", "pattern": "^hypothesis_[0-9A-F]{26}$" },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-F]{26}$" },
    "parentNodeId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "parentNodeKind": { "type": "string", "enum": ["problem", "hypothesis"] },
    "title": { "type": "string", "maxLength": 240 },
    "statement": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "falsificationCriteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 },
      "minItems": 1,
      "uniqueItems": true
    },
    "derivedFromEvidenceIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^evidence_[0-9A-F]{26}$" },
      "uniqueItems": true
    },
    "status": { "type": "string", "enum": ["unverified", "blocked", "confirmed", "rejected"] }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/domain/v1/entity.schema.json",
  "allOf": [
    { "$ref": "../../common/base-node.schema.json" },
    {
      "type": "object",
      "required": ["kind", "entityKind", "name", "locator"],
      "properties": {
        "kind": { "const": "investigation.entity" },
        "entityKind": { "type": "string", "enum": ["service", "module", "file", "function", "api", "db", "table", "queue", "topic", "cache", "config", "tenant", "workflow", "external_api"] },
        "name": { "type": "string", "minLength": 1, "maxLength": 240 },
        "locator": { "type": "object", "additionalProperties": true }
      }
    }
  ],
  "unevaluatedProperties": false
}
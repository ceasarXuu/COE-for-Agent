{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/domain/v1/issue.schema.json",
  "allOf": [
    { "$ref": "../../common/base-node.schema.json" },
    {
      "type": "object",
      "required": ["kind", "title", "summary", "issueKind", "status", "priority"],
      "properties": {
        "kind": { "const": "investigation.issue" },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "issueKind": { "type": "string", "enum": ["question", "symptom", "unresolved"] },
        "status": { "type": "string", "enum": ["open", "paused", "resolved", "closed", "merged", "accepted"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "blocking": { "type": "boolean" },
        "scopeRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "contextRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "relatedIssueIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^issue_[0-9A-HJKMNP-TV-Z]{26}$" },
          "uniqueItems": true
        }
      }
    }
  ],
  "unevaluatedProperties": false
}

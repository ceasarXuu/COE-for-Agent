{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/domain/v1/symptom.schema.json",
  "allOf": [
    { "$ref": "../../common/base-node.schema.json" },
    {
      "type": "object",
      "required": ["kind", "statement", "severity", "reproducibility"],
      "properties": {
        "kind": { "const": "investigation.symptom" },
        "statement": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "reproducibility": { "type": "string", "enum": ["always", "often", "intermittent", "rare", "unknown"] },
        "critical": { "type": "boolean" },
        "affectedRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    }
  ],
  "unevaluatedProperties": false
}
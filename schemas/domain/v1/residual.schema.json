{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/domain/v1/residual.schema.json",
  "allOf": [
    { "$ref": "../../common/base-node.schema.json" },
    {
      "type": "object",
      "required": ["kind", "statement", "status", "severity"],
      "properties": {
        "kind": { "const": "investigation.residual" },
        "statement": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "status": { "type": "string", "enum": ["open", "reduced", "resolved", "accepted"] },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "relatedSymptomIds": { "type": "array", "items": { "type": "string", "pattern": "^symptom_[0-9A-HJKMNP-TV-Z]{26}$" }, "uniqueItems": true }
      }
    }
  ],
  "unevaluatedProperties": false
}
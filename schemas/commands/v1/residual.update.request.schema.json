{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/residual.update.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "residualId", "newStatus"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "residualId": { "type": "string", "pattern": "^residual_[0-9A-HJKMNP-TV-Z]{26}$" },
    "newStatus": { "type": "string", "enum": ["reduced", "resolved", "accepted"] },
    "rationale": { "type": "string", "maxLength": 2000 },
    "reasonFactIds": { "type": "array", "items": { "type": "string", "pattern": "^fact_[0-9A-HJKMNP-TV-Z]{26}$" }, "uniqueItems": true },
    "reasonHypothesisIds": { "type": "array", "items": { "type": "string", "pattern": "^hypothesis_[0-9A-HJKMNP-TV-Z]{26}$" }, "uniqueItems": true }
  }
}
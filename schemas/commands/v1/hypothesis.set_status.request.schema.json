{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/hypothesis.set_status.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "hypothesisId", "newStatus"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 128 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-F]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "hypothesisId": { "type": "string", "pattern": "^hypothesis_[0-9A-F]{26}$" },
    "newStatus": { "type": "string", "enum": ["blocked", "confirmed", "rejected", "unverified"] },
    "reason": { "type": "string", "minLength": 1, "maxLength": 4000 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/issue.record.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "issueKind", "title", "summary", "priority"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "issueKind": { "type": "string", "enum": ["question", "symptom", "unresolved"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "blocking": { "type": "boolean" },
    "scopeRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "blockedRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "relatedSymptomIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^symptom_[0-9A-HJKMNP-TV-Z]{26}$" },
      "uniqueItems": true
    },
    "reproducibility": { "type": "string", "enum": ["always", "often", "intermittent", "rare", "unknown"] }
  }
}

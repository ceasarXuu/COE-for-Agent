{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/gap.open.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "question", "priority"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "question": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "blockedRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
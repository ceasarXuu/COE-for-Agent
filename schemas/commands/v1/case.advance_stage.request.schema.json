{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/case.advance_stage.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "stage"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "stage": { "type": "string", "enum": ["intake", "scoping", "evidence_collection", "hypothesis_competition", "discriminative_testing", "repair_preparation", "repair_validation", "closed"] },
    "reason": { "type": "string", "maxLength": 2000 }
  }
}
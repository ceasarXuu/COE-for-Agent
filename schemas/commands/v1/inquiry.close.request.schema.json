{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/inquiry.close.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "inquiryId", "resolutionKind"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "inquiryId": { "type": "string", "pattern": "^inquiry_[0-9A-HJKMNP-TV-Z]{26}$" },
    "resolutionKind": { "type": "string", "enum": ["answered", "superseded", "invalid", "merged"] },
    "reason": { "type": "string", "maxLength": 2000 },
    "supportingDecisionId": { "type": "string", "pattern": "^decision_[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
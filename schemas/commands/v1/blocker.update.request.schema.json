{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/blocker.update.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "blockerId"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 128 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-F]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "blockerId": { "type": "string", "pattern": "^blocker_[0-9A-F]{26}$" },
    "description": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "possibleWorkarounds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 },
      "uniqueItems": true
    }
  }
}

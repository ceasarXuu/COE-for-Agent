{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/entity.register.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "entityKind", "name", "locator"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "entityKind": { "type": "string", "enum": ["service", "module", "file", "function", "api", "db", "table", "queue", "topic", "cache", "config", "tenant", "workflow", "external_api"] },
    "name": { "type": "string", "minLength": 1, "maxLength": 240 },
    "locator": { "type": "object", "additionalProperties": true }
  }
}
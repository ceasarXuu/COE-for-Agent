{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/symptom.report.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "statement", "severity", "reproducibility"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "statement": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "reproducibility": { "type": "string", "enum": ["always", "often", "intermittent", "rare", "unknown"] },
    "affectedRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
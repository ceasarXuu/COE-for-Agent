{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/problem.add_reference_material.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "problemId", "materialKind", "title"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 128 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-F]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "problemId": { "type": "string", "pattern": "^problem_[0-9A-F]{26}$" },
    "materialKind": {
      "type": "string",
      "enum": ["log", "code", "trace", "screenshot", "conversation", "ticket", "document", "other"]
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "contentRef": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "note": { "type": "string", "minLength": 1, "maxLength": 4000 }
  },
  "oneOf": [
    { "required": ["contentRef"] },
    { "required": ["note"] }
  ]
}

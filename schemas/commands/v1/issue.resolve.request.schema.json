{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/commands/v1/issue.resolve.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotencyKey", "caseId", "ifCaseRevision", "issueId", "resolution", "rationale"],
  "properties": {
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "ifCaseRevision": { "type": "integer", "minimum": 1 },
    "issueId": { "type": "string", "minLength": 1 },
    "resolution": { "type": "string", "enum": ["resolved", "accepted", "answered", "merged"] },
    "rationale": { "type": "string", "minLength": 1, "maxLength": 4000 }
  }
}

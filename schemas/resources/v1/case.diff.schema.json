{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/case.diff.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fromRevision", "toRevision", "changedNodeIds", "changedEdgeKeys", "stateTransitions", "summary"],
      "properties": {
        "fromRevision": { "type": "integer", "minimum": 0 },
        "toRevision": { "type": "integer", "minimum": 0 },
        "changedNodeIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "changedEdgeKeys": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "stateTransitions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nodeId", "kind", "fromStatus", "toStatus"],
            "properties": {
              "nodeId": { "type": "string" },
              "kind": { "type": "string" },
              "fromStatus": { "type": ["string", "null"] },
              "toStatus": { "type": ["string", "null"] }
            }
          }
        },
        "summary": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

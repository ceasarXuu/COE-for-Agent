{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/inquiry.panel.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inquiry", "hypotheses", "experiments", "gaps"],
      "properties": {
        "inquiry": { "type": "object", "additionalProperties": true },
        "hypotheses": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "experiments": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "gaps": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      }
    }
  }
}
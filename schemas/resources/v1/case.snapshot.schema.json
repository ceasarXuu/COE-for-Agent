{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/case.snapshot.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case", "counts"],
      "properties": {
        "case": { "type": "object", "additionalProperties": true },
        "counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["profileVersion", "mcpSurfaceVersion", "capabilities", "tools", "resources"],
  "properties": {
    "profileVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "mcpSurfaceVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "capabilities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "tools": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "resources": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
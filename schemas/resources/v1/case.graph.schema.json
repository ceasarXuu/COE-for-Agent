{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/case.graph.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["focusId", "projectionModel", "nodes", "edges"],
      "properties": {
        "focusId": { "type": ["string", "null"] },
        "projectionModel": { "type": "string", "enum": ["canonical", "legacy"] },
        "nodes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "edges": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      }
    }
  }
}

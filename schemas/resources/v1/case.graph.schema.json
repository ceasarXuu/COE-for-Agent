{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/case.graph.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["focusId", "projectionModel", "nodes", "edges"],
      "properties": {
        "focusId": { "type": ["string", "null"] },
        "projectionModel": { "type": "string", "enum": ["canonical"] },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "label", "status", "revision"],
            "properties": {
              "id": { "type": "string" },
              "kind": {
                "type": "string",
                "enum": ["problem", "hypothesis", "blocker", "repair_attempt", "evidence_ref"]
              },
              "label": { "type": "string" },
              "payload": { "type": "object", "additionalProperties": true },
              "summary": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] },
              "revision": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "type", "fromId", "toId"],
            "properties": {
              "key": { "type": "string" },
              "type": { "type": "string", "enum": ["structural"] },
              "fromId": { "type": "string" },
              "toId": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/case.timeline.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["eventId", "eventType", "caseRevision", "occurredAt"],
            "properties": {
              "eventId": { "type": "string" },
              "eventType": { "type": "string" },
              "caseRevision": { "type": "integer", "minimum": 1 },
              "occurredAt": { "type": "string", "format": "date-time" },
              "summary": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
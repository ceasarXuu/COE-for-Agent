{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/resources/v1/case.evidence-pool.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["headRevision", "projectionRevision", "requestedRevision", "stale", "historical", "data"],
  "properties": {
    "headRevision": { "type": "integer", "minimum": 0 },
    "projectionRevision": { "type": "integer", "minimum": 0 },
    "requestedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "stale": { "type": "boolean" },
    "historical": { "type": "boolean" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["evidenceId", "kind", "title", "summary", "provenance", "confidence", "revision"],
            "properties": {
              "evidenceId": { "type": "string", "pattern": "^evidence_" },
              "kind": { "type": "string" },
              "title": { "type": "string" },
              "summary": { "type": ["string", "null"] },
              "provenance": { "type": ["string", "null"] },
              "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
              "revision": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}

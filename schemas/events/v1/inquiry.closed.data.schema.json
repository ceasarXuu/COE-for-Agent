{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/events/v1/inquiry.closed.data.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "caseId", "caseRevision", "inquiryId", "resolutionKind"],
  "properties": {
    "eventId": { "type": "string" },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "caseRevision": { "type": "integer", "minimum": 1 },
    "inquiryId": { "type": "string", "pattern": "^inquiry_[0-9A-HJKMNP-TV-Z]{26}$" },
    "resolutionKind": { "type": "string" },
    "reason": { "type": "string" }
  }
}
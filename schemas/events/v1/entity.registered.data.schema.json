{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/events/v1/entity.registered.data.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "caseId", "caseRevision", "entityId", "entityKind", "name"],
  "properties": {
    "eventId": { "type": "string" },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "caseRevision": { "type": "integer", "minimum": 1 },
    "entityId": { "type": "string", "pattern": "^entity_[0-9A-HJKMNP-TV-Z]{26}$" },
    "entityKind": { "type": "string" },
    "name": { "type": "string" }
  }
}
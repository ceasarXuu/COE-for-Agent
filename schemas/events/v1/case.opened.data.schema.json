{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/events/v1/case.opened.data.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "caseId", "caseRevision", "title", "severity"],
  "properties": {
    "eventId": { "type": "string" },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "caseRevision": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
  }
}
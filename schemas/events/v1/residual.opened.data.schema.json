{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.coe.local/events/v1/residual.opened.data.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "caseId", "caseRevision", "residualId", "statement", "severity"],
  "properties": {
    "eventId": { "type": "string" },
    "caseId": { "type": "string", "pattern": "^case_[0-9A-HJKMNP-TV-Z]{26}$" },
    "caseRevision": { "type": "integer", "minimum": 1 },
    "residualId": { "type": "string", "pattern": "^residual_[0-9A-HJKMNP-TV-Z]{26}$" },
    "statement": { "type": "string" },
    "severity": { "type": "string" }
  }
}